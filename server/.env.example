OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
PORT=3000
SESSION_TTL_MS=43200000
OAUTH_STATE_TTL_MS=600000
# 文字列を指定するとメールセッションを暗号化して保持します（本番では必須）
# MAIL_SESSION_SECRET=change-this-secret
# MAIL_OAUTH_REDIRECT_URI=http://localhost:3000/api/mail/oauth/callback

# Gmail OAuth
# MAIL_OAUTH_GMAIL_CLIENT_ID=
# MAIL_OAUTH_GMAIL_CLIENT_SECRET=

# Yahoo OAuth
# MAIL_OAUTH_YAHOO_CLIENT_ID=
# MAIL_OAUTH_YAHOO_CLIENT_SECRET=

# Outlook OAuth (Microsoft Entra)
# MAIL_OAUTH_OUTLOOK_CLIENT_ID=
# MAIL_OAUTH_OUTLOOK_CLIENT_SECRET=

# KeyNest Push (FCM HTTP v1)
# FCM_PROJECT_ID=
# いずれか1つを設定:
# FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FCM_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# APNs direct push (optional, iOS向けに優先送信。失敗時FCMへフォールバック)
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_BUNDLE_ID=com.keynest.app
# APNS_AUTH_KEY_PATH=./secrets/AuthKey_XXXXXXXXXX.p8
# APNS_AUTH_KEY_BASE64=
# APNS_PRODUCTION=true

# Optional: comma separated origins for production CORS hardening
# CORS_ORIGINS=https://app.venemo.com,https://admin.venemo.com

# Venemo Plus pricing (server source of truth)
# PLUS_MONTHLY_PRICE_YEN=800
# PLUS_YEARLY_PRICE_YEN=8000

# Web Billing (Stripe)
# STRIPE_PUBLIC_KEY=pk_live_xxx
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_PRICE_ID_MONTHLY=price_xxx_monthly
# STRIPE_PRICE_ID_YEARLY=price_xxx_yearly
# STRIPE_SUCCESS_URL=https://app.venemo.com/#/settings?billing=success
# STRIPE_CANCEL_URL=https://app.venemo.com/#/settings?billing=cancel
# SUBSCRIPTION_WEBHOOK_SECRET=change-me
# ENABLE_BILLING_STUB=true # 開発時のみ true（本番は false 推奨）

# パスワードログイン（本番は false 推奨）
# ALLOW_PASSWORD_LOGIN=false

# Mobile/Desktop Billing product IDs
# IOS_PLUS_MONTHLY_PRODUCT_ID=venemo.plus.monthly
# IOS_PLUS_YEARLY_PRODUCT_ID=venemo.plus.yearly
# ANDROID_PLUS_MONTHLY_PRODUCT_ID=venemo.plus.monthly
# ANDROID_PLUS_YEARLY_PRODUCT_ID=venemo.plus.yearly
