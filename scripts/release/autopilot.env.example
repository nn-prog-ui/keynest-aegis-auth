# Copy to scripts/release/autopilot.env and set real values.

# Timezone used by date routing.
TZ_REGION=Asia/Tokyo

# App Store Connect API
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# base64 of AuthKey_xxx.p8 (single line)
APP_STORE_CONNECT_API_KEY_BASE64=

# Optional: if fastlane cannot infer key path, keep empty and let autopilot use temp file.
# APP_STORE_CONNECT_API_KEY_PATH=

# Firebase/FCM (server-side)
FCM_PROJECT_ID=
# Set one of the following:
# FCM_SERVICE_ACCOUNT_PATH=/absolute/path/to/firebase-service-account.json
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FCM_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# APNs direct push (optional)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.aegisauth.app
# Set one of the following:
# APNS_AUTH_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
# APNS_AUTH_KEY_BASE64=LS0tLS1CRUdJTiBQUklWQVRFIEtFWS0tLS0t...
APNS_PRODUCTION=true
